# ── Server ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5001

# ── PostgreSQL ────────────────────────────────────────────────────
# On Render: use DATABASE_URL (auto-provided by Render PostgreSQL)
# For local dev: use individual vars below
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Local dev only (ignored when DATABASE_URL is set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bus_tracking
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── Redis ─────────────────────────────────────────────────────────
# On Render/Upstash: use REDIS_URL (rediss:// for TLS)
# For local dev: use individual vars below
REDIS_URL=rediss://default:password@host:6379

# Local dev only (ignored when REDIS_URL is set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-change-in-production
JWT_EXPIRES_IN=604800
REFRESH_TOKEN_EXPIRES_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Use * to allow all (not recommended for production)
CORS_ORIGIN=https://your-frontend.onrender.com,https://your-app.com

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Misc ──────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_RETENTION_DAYS=90
GPS_UPDATE_INTERVAL=5000
LOCATION_CACHE_TTL=30
