# Server Configuration
NODE_ENV=development
PORT=5001
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bus_tracking
DB_USER=postgres
DB_PASSWORD=your_password_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-change-in-production
JWT_EXPIRES_IN=604800
REFRESH_TOKEN_EXPIRES_DAYS=30

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:19006,http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# GPS / Location
GPS_UPDATE_INTERVAL=5000
LOCATION_CACHE_TTL=30
DWELL_TIME_MINUTES=1

# Logging
LOG_LEVEL=info
LOG_RETENTION_DAYS=90

# Redis Adapter (set true for multi-instance deployment)
REDIS_ADAPTER=false
